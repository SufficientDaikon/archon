# Model providers (BYOK — bring your own key)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Provider role overrides (optional — defaults to role field in providers.yaml)
# DRAFT_PROVIDER=gemini
# VERIFY_PROVIDER=groq

# Twilio (WhatsApp channel)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM=whatsapp:+14155238886

# Server
PORT=8000

# Development — set to 1 to skip Twilio signature validation (NEVER in production)
DEV_SKIP_VALIDATION=0

# Archon root directory (auto-detected from package path; override if needed)
# ARCHON_ROOT=/path/to/archon
